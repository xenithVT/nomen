config_version=5

[application]

config/name="nomen"
config/version="0.1"
run/main_scene="uid://chi2jrix7bh0y"
config/custom_user_dir_name="user://nomen"
config/quit_on_go_back=false
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=144
boot_splash/bg_color=Color(0.021434637, 0.021434635, 0.021434633, 1)
config/icon="uid://dugpo2ngqrbyg"

[autoload]

DialogueManager="*uid://c3rodes2l3gxb"
Gamestate="*uid://b35nl8w37ih2w"
Dialoguestate="*uid://cb0l6n36usaee"
Playermanager="*uid://ddnnpvw1jcab3"
Combatmanager="*uid://ci3o28nkyknx0"
SaveLoad="*uid://cqfs5e5t5kh6e"
SaveData="*uid://ccp75fbfjqgmv"

[dialogue_manager]

runtime/balloon_path="res://nodes/dialogueballoon.tscn"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/mode=4
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="viewport"

[editor_plugins]

